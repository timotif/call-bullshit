GRADIUM_API_KEY=<your_gradium_api_key_here>
TAVILY_API_KEY=<your_tavily_api_key_here>
NEBIUS_API_KEY=<your_nebius_api_key_here>

# Optional tuning (defaults shown)
# Models. All three legs on one fast non-thinking MoE (Tavily does the deciding).
# Do NOT use a *-Thinking* or reasoning model here: with our short max_tokens they
# spend the whole budget reasoning and return empty content (dead air in TTS).
JUDGE_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
EXTRACT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
REBUTTAL_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# Tavily results fetched (latency is flat 3-5; judge reads all of them) and the
# per-result snippet cap fed to the judge.
TAVILY_MAX_RESULTS=5
SNIPPET_CHARS=400
VAD_THRESHOLD=0.7
VAD_STEPS_TO_END=8
LIVE_CHECK_WORDS=15
LIVE_CHECK_MIN_WORDS=10
BS_THRESHOLD=1.0
BS_DECAY=0.3
CALIBRATION_MARGIN=0.5
CALIBRATION_MAX=17.0
# Shuffle openers with duration in [budget, budget + BARKER_LENGTH_BAND]
BARKER_LENGTH_BAND=1.0
CALIBRATE=1
TTS_PREBUFFER_CHUNKS=2
MAX_REBUTTAL_SECONDS=30
DASHBOARD_PORT=8765
INPUT_DEVICE=
DEBUG=0
