GRADIUM_API_KEY=<your_gradium_api_key_here>
TAVILY_API_KEY=<your_tavily_api_key_here>
NEBIUS_API_KEY=<your_nebius_api_key_here>

# Optional tuning (defaults shown)
# Models. Extraction + judge on a fast MoE (Tavily evidence does the deciding);
# rebuttal stays on 70B since it's hidden behind the barker, not reaction-critical.
JUDGE_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
EXTRACT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
REBUTTAL_MODEL=meta-llama/Llama-3.3-70B-Instruct
VAD_THRESHOLD=0.7
VAD_STEPS_TO_END=8
LIVE_CHECK_WORDS=15
LIVE_CHECK_MIN_WORDS=10
BS_THRESHOLD=1.0
CALIBRATION_MARGIN=1.5
CALIBRATION_MAX=17.0
CALIBRATE=1
DASHBOARD_PORT=8765
INPUT_DEVICE=
DEBUG=0
